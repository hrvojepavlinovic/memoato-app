DATABASE_URL=postgresql://memoato@localhost/memoato?host=/var/run/postgresql&sslmode=disable

# Required in production
NODE_ENV=production
PORT=5051
WASP_SERVER_URL=https://api.memoato.com
WASP_WEB_CLIENT_URL=https://app.memoato.com
JWT_SECRET=

# Comma-separated email allowlist for admin role promotion + /sudo access.
MEMOATO_ADMIN_EMAILS=

# Email (required for email auth)
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_PORT=

# Google auth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Private raw-entry ingest for local MCP/automation.
# Do not commit real values. Token is sent as Authorization: Bearer <token>.
MEMOATO_MCP_TOKEN=
MEMOATO_MCP_USER_ID=
MEMOATO_MCP_USER_EMAIL=
MEMOATO_MCP_USERNAME=

# Optional AI fallback for raw-entry parsing. Deterministic parsing works without this.
OPENROUTER_API_KEY=
MEMOATO_AI_MODEL=google/gemini-3.1-flash-lite
MEMOATO_AI_FALLBACK_MODEL=openai/gpt-4.1-mini
