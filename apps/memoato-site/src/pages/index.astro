---
import BaseLayout from "../layouts/BaseLayout.astro";
import StatsRow from "../components/StatsRow.astro";

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "memoato",
  operatingSystem: "Web",
  applicationCategory: "ProductivityApplication",
  url: "https://app.memoato.com",
  description: "A low-friction life logger that turns messy notes into useful personal memory.",
  publisher: { "@id": "https://memoato.com/#organization" },
  isAccessibleForFree: true,
};
const softwareJsonLdString = JSON.stringify(softwareJsonLd);
---

<BaseLayout
  title="memoato: useful memory from messy life logs"
  description="Type what happened. Memoato turns raw life notes into structured memory, searchable facts, and useful recall."
  canonicalPath="/"
>
  <script slot="head" type="application/ld+json" set:html={softwareJsonLdString} />

  <section class="container hero memory-hero">
    <div class="hero-copy">
      <div class="pill">Raw notes · Structured facts · MCP-ready</div>
      <h1 class="h1" style="margin-top: 1rem">Type what happened. Remember what matters.</h1>
      <p class="lead">
        memoato is a low-friction life logger that turns messy everyday notes into useful memory.
        Log health, training, family, money, errands, and context in plain text.
      </p>
      <div class="hero-actions">
        <a class="btn primary" href="https://app.memoato.com" rel="noreferrer" referrerpolicy="no-referrer">
          Open app
        </a>
        <a class="btn" href="/help">How it works</a>
        <a class="btn" href="/blog/why-memoato">Read the story</a>
      </div>
    </div>

    <div class="memory-demo" aria-label="Memoato logging example">
      <div class="demo-card-top">
        <div>
          <div class="demo-label">Plain text log</div>
          <div class="demo-caption">from app, chat, or MCP</div>
        </div>
      </div>

      <div class="demo-input">
        Low energy today. Skipped gym, but walked 20 minutes after lunch. Slept badly again. Big client call at 9am.
      </div>

      <div class="demo-route" aria-hidden="true">
        <span></span>
        <strong>memoato parses context</strong>
        <span></span>
      </div>

      <div class="demo-label">Memoato understands</div>
      <div class="fact-list">
        <div class="fact-row">
          <span class="fact-kicker">Energy</span>
          <span>low · today</span>
        </div>
        <div class="fact-row">
          <span class="fact-kicker">Movement</span>
          <span>gym skipped · 20 min walk · after lunch</span>
        </div>
        <div class="fact-row">
          <span class="fact-kicker">Context</span>
          <span>bad sleep again · client call at 9am</span>
        </div>
      </div>

      <div class="mcp-box">
        <div class="mcp-mark">MCP</div>
        <div>
          <div class="mcp-title">ChatGPT and automations can log directly.</div>
          <div class="mcp-copy">Scoped API keys let clients write raw entries without exposing your account.</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section mcp-setup-section">
    <div class="container">
      <div class="mcp-setup">
        <div class="mcp-setup-copy">
          <div class="card-kicker">MCP setup</div>
          <div class="h2">Connect Claude or Codex in minutes</div>
          <p class="muted">
            Install the local MCP bridge, create a scoped Memoato API key, then paste one config into your AI client.
          </p>
          <div class="mcp-steps">
            <a href="https://app.memoato.com/profile" rel="noreferrer" referrerpolicy="no-referrer">
              1. Create API key
            </a>
            <span>2. Run installer</span>
            <span>3. Add Claude or Codex</span>
          </div>
        </div>

        <div class="mcp-terminal" data-mcp-tabs aria-label="Memoato MCP setup terminal">
          <div class="mcp-terminal-top">
            <div class="terminal-dots" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="terminal-tabs" role="tablist" aria-label="MCP setup snippets">
              <button class="terminal-tab is-active" type="button" data-mcp-tab="install">Install</button>
              <button class="terminal-tab" type="button" data-mcp-tab="codex">Codex</button>
              <button class="terminal-tab" type="button" data-mcp-tab="claude">Claude</button>
            </div>
          </div>

          <div class="terminal-panel is-active" data-mcp-panel="install">
            <div class="terminal-title">One command install</div>
            <pre><code>{`curl -fsSL https://raw.githubusercontent.com/hrvojepavlinovic/memoato-app/main/tools/memoato-mcp/install.sh | bash`}</code></pre>
            <div class="terminal-hint">
              Installs the MCP bridge to <code>~/.memoato/bin/memoato-mcp</code>. Requires git, Node, and npm.
            </div>
          </div>

          <div class="terminal-panel" data-mcp-panel="codex">
            <div class="terminal-title">Add to Codex</div>
            <pre><code>{`codex mcp add memoato \\
  --env MEMOATO_MCP_TOKEN=memoato_live_... \\
  -- "$HOME/.memoato/bin/memoato-mcp"`}</code></pre>
            <div class="terminal-hint">
              Replace <code>memoato_live_...</code> with the key from <a href="https://app.memoato.com/profile" rel="noreferrer" referrerpolicy="no-referrer">Profile -> API keys</a>.
            </div>
          </div>

          <div class="terminal-panel" data-mcp-panel="claude">
            <div class="terminal-title">Claude Desktop config</div>
            <pre><code>{`{
  "mcpServers": {
    "memoato": {
      "command": "/Users/YOU/.memoato/bin/memoato-mcp",
      "env": {
        "MEMOATO_MCP_TOKEN": "memoato_live_..."
      }
    }
  }
}`}</code></pre>
            <div class="terminal-hint">
              Use the absolute path printed by the installer. Then restart Claude Desktop.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section memory-stats-section">
    <div class="container">
      <StatsRow />
    </div>
  </section>

  <section class="section" style="padding-top: 2.5rem">
    <div class="container">
      <div class="value-surface">
        <div class="value-header">
          <div class="h2">A memory system, not another habit app</div>
          <div class="muted" style="max-width: 70ch">
            Keep the input simple. Let the system do the sorting, labeling, and recall.
          </div>
        </div>

        <div class="feature-grid value-features">
          <div class="feature-line">
            <div class="feature-icon" aria-hidden="true">
              <svg
                class="feature-svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M13 2 3 14h8l-1 8 10-12h-8l1-8Z" />
              </svg>
            </div>
            <div>
              <div class="feature-title">Raw log first</div>
              <div class="muted">Write the thing naturally. The original note is always preserved.</div>
            </div>
          </div>

          <div class="feature-line">
            <div class="feature-icon" aria-hidden="true">
              <svg
                class="feature-svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="4" y="4" width="7" height="7" rx="1" />
                <rect x="13" y="4" width="7" height="7" rx="1" />
                <rect x="4" y="13" width="7" height="7" rx="1" />
                <rect x="13" y="13" width="7" height="7" rx="1" />
              </svg>
            </div>
            <div>
              <div class="feature-title">Facts from text</div>
              <div class="muted">Exercise, symptoms, temperature, money, duration, distance, and context become structured data.</div>
            </div>
          </div>

          <div class="feature-line">
            <div class="feature-icon" aria-hidden="true">
              <svg
                class="feature-svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="9" />
                <path d="M12 7v6l3 2" />
              </svg>
            </div>
            <div>
              <div class="feature-title">Learns your defaults</div>
              <div class="muted">If curls are usually 10 kg, Memoato can assume that and show it clearly.</div>
            </div>
          </div>

          <div class="feature-line">
            <div class="feature-icon" aria-hidden="true">
              <svg
                class="feature-svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M3 3v18h18" />
                <path d="m7 15 4-4 3 3 6-7" />
              </svg>
            </div>
            <div>
              <div class="feature-title">MCP support</div>
              <div class="muted">Let ChatGPT or small automations send raw entries through scoped, revocable API keys.</div>
            </div>
          </div>

          <div class="feature-line">
            <div class="feature-icon" aria-hidden="true">
              <svg
                class="feature-svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 12a9 9 0 1 1-3-6.7" />
                <path d="M21 3v7h-7" />
              </svg>
            </div>
            <div>
              <div class="feature-title">Forgiving review</div>
              <div class="muted">Correct assumptions when needed. Skip the form when the guess is right.</div>
            </div>
          </div>

          <div class="feature-line">
            <div class="feature-icon" aria-hidden="true">
              <svg
                class="feature-svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M7 11V8a5 5 0 0 1 10 0v3" />
                <path d="M6 11h12v10H6V11Z" />
              </svg>
            </div>
            <div>
              <div class="feature-title">Connects later</div>
              <div class="muted">Todoist, calendar, mail, Obsidian, and wearable exports can become sources.</div>
            </div>
          </div>
        </div>

        <div class="card-actions value-actions">
          <a class="btn" href="/help">Help & FAQ</a>
          <a class="btn" href="/adhd">ADHD-friendly</a>
          <a class="btn" href="/privacy">Privacy</a>
          <a class="btn" href="/open-source">Open source</a>
          <a class="btn" href="/changelog">Changelog</a>
          <a class="btn" href="/blog/why-memoato">Why memoato</a>
          <a class="btn" href="/blog/timeline">Timeline</a>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll("[data-mcp-tabs]").forEach((root) => {
      const tabs = Array.from(root.querySelectorAll("[data-mcp-tab]"));
      const panels = Array.from(root.querySelectorAll("[data-mcp-panel]"));
      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const id = tab.getAttribute("data-mcp-tab");
          tabs.forEach((item) => item.classList.toggle("is-active", item === tab));
          panels.forEach((panel) => {
            panel.classList.toggle("is-active", panel.getAttribute("data-mcp-panel") === id);
          });
        });
      });
    });
  </script>

  <section class="section" style="padding-top: 2.5rem">
    <div class="container">
      <div class="h2" style="text-align: left">What it remembers</div>
      <div class="muted usecases-subtitle">
        Messy real-life notes become timelines, totals, symptoms, and context you can actually use.
      </div>

      <div class="usecase-grid">
        <a class="card card-link" href="/minimal-habit-tracker">
          <div class="card-kicker">Training</div>
          <div class="card-title">Sets, weights, pain, and patterns</div>
          <div class="card-body">Log reps and notes in one sentence. See what changed before something hurt.</div>
          <div class="card-cta">
            <span>Read</span>
            <span aria-hidden="true">→</span>
          </div>
        </a>

        <a class="card card-link" href="/adhd">
          <div class="card-kicker">Family and health</div>
          <div class="card-title">Symptoms, temperatures, and episodes</div>
          <div class="card-body">Remember who was sick, when it started, and how often it repeats.</div>
          <div class="card-cta">
            <span>Read</span>
            <span aria-hidden="true">→</span>
          </div>
        </a>

        <a class="card card-link" href="/privacy-first">
          <div class="card-kicker">Life admin</div>
          <div class="card-title">Purchases, cars, errands, and reminders</div>
          <div class="card-body">Turn small logs into a searchable history of what you bought, fixed, paid, or promised.</div>
          <div class="card-cta">
            <span>Read</span>
            <span aria-hidden="true">→</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card donate-card">
        <div>
          <div class="h2">Early, open, and changing fast</div>
          <div class="muted">memoato is being rebuilt around raw logging, structured memory, and useful recall.</div>
        </div>
        <a
          class="btn accent"
          href="https://app.memoato.com"
          rel="noreferrer"
          referrerpolicy="no-referrer"
        >
          Try memoato
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
