---
import EditorialPageLayout from "../../layouts/EditorialPageLayout.astro";

const postModules = import.meta.glob("./*.md", { eager: true });
const posts = Object.values(postModules as Record<string, any>).sort((a, b) => {
  const da = new Date(a.frontmatter.date ?? 0).getTime();
  const db = new Date(b.frontmatter.date ?? 0).getTime();
  return db - da;
});

function fmtDate(input: any): string | null {
  if (!input) return null;
  const d = new Date(input);
  if (Number.isNaN(d.getTime())) return null;
  return d.toLocaleDateString(undefined, { year: "numeric", month: "short", day: "2-digit" });
}
---

<EditorialPageLayout
  title="Journal · memoato"
  description="Notes about personal memory, low-friction logging, product decisions, and building Memoato in the open."
  canonicalPath="/blog"
  eyebrow="Memoato journal"
  heading="Thinking in public, remembering in private."
  deck="Product notes, design decisions, and practical ideas for keeping the parts of life that normally disappear between apps."
  accent="ink"
  wide={true}
>
  <div class="post-list">
    {posts.map((p) => {
      const title = p.frontmatter.title ?? p.url;
      const desc = p.frontmatter.description ?? "";
      const dateLabel = fmtDate(p.frontmatter.date);
      return (
        <a class="card post-card" href={p.url}>
          {dateLabel ? <div class="post-kicker">{dateLabel}</div> : null}
          <div class="post-title">{title}</div>
          {desc ? <div class="post-desc">{desc}</div> : null}
        </a>
      );
    })}
  </div>
</EditorialPageLayout>
