datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Use Prisma Schema file to define your entities: https://www.prisma.io/docs/concepts/components/prisma-schema.
// Run `wasp db migrate-dev` in the CLI to create the database tables,
// then run `wasp db studio` to open Prisma Studio and view your db models.
model User {
  id                      String   @id @default(uuid())
  username                String   @unique
  email                   String?  @unique
  role                    String   @default("user")
  firstName               String?
  lastName                String?
  nextUpEnabled           Boolean  @default(false)
  themePreference         String?
  quickLogFabSide         String   @default("right")
  homeCategoryLayout      String   @default("list")
  activeKcalRollupEnabled Boolean?
  publicStatsEnabled      Boolean  @default(false)
  publicStatsToken        String?  @unique
  publicStatsCategoryIds  Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  Category               Category[]
  Event                  Event[]
  ApiKey                 ApiKey[]
  MemoryFact             MemoryFact[]
  MemoryProcessingRun    MemoryProcessingRun[]
  MemoryCorrection       MemoryCorrection[]
  MemoryAlias            MemoryAlias[]
  MemoryEntity           MemoryEntity[]
  MemoryInference        MemoryInference[]
  MemoryEmbedding        MemoryEmbedding[]
  MemoryConcept          MemoryConcept[]
  MemoryConceptAlias     MemoryConceptAlias[]
  MemoryEntryConcept     MemoryEntryConcept[]
  MemoryConceptEmbedding MemoryConceptEmbedding[]
  WorkspacesCreated      Workspace[]              @relation("WorkspaceCreator")
  WorkspaceMemberships   WorkspaceMember[]
}

enum EventKind {
  SESSION
  NOTE
}

enum CategoryType {
  NUMBER
  DO
  DONT
  GOAL
}

model Category {
  id String @id @default(uuid())

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  source   String @default("focus")
  sourceId Int?

  title              String
  slug               String?
  type               String?
  kind               String?
  unit               String?
  chartType          String?
  categoryType       CategoryType @default(NUMBER)
  accentHex          String       @default("#0A0A0A")
  emoji              String?
  isSystem           Boolean      @default(false)
  sortOrder          Int?
  bucketAggregation  String?
  goalDirection      String?
  goalWeekly         Float?
  goalValue          Float?
  targetCount        Int?
  period             String?
  targetDuration     Int?
  fieldsSchema       Json?
  rollupToActiveKcal Boolean      @default(false)
  scheduleEnabled    Boolean      @default(false)
  scheduleType       String?
  scheduleDays       Json?
  scheduleTime       String?

  sourceCreatedAt  DateTime?
  sourceArchivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events         Event[]
  memoryFacts    MemoryFact[]
  memoryAliases  MemoryAlias[]
  memoryConcepts MemoryConcept[]

  @@unique([source, sourceId])
  @@unique([userId, slug])
  @@index([userId])
}

model CategoryTemplate {
  id String @id

  key   String @unique
  title String

  categoryType      CategoryType @default(NUMBER)
  chartType         String?
  period            String?
  unit              String?
  bucketAggregation String?
  goalDirection     String?
  goalWeekly        Float?
  goalValue         Float?
  accentHex         String       @default("#0A0A0A")
  emoji             String?
  fieldsSchema      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id String @id @default(uuid())

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  source   String    @default("focus")
  kind     EventKind
  sourceId Int?

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?

  rawText  String?
  amount   Float?
  duration Int?
  data     Json?

  sourceCreatedAt  DateTime?
  sourceFinishedAt DateTime?

  createdAt  DateTime @default(now())
  occurredAt DateTime @default(now())
  occurredOn DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  updatedAt  DateTime @updatedAt

  rawMemoryFacts       MemoryFact[]          @relation("RawMemoryFacts")
  derivedMemoryFacts   MemoryFact[]          @relation("DerivedMemoryFacts")
  memoryProcessingRuns MemoryProcessingRun[]
  memoryCorrections    MemoryCorrection[]
  memoryEmbeddings     MemoryEmbedding[]
  memoryConcepts       MemoryEntryConcept[]

  @@unique([source, kind, sourceId])
  @@index([userId])
  @@index([occurredOn])
  @@index([occurredAt])
}

// The raw Event(kind=NOTE) remains the source of truth. These rows are a
// rebuildable, reviewable interpretation layer and never replace rawText.
model MemoryFact {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  rawEntry   Event  @relation("RawMemoryFacts", fields: [rawEntryId], references: [id], onDelete: Cascade)
  rawEntryId String

  derivedEvent   Event?  @relation("DerivedMemoryFacts", fields: [derivedEventId], references: [id], onDelete: SetNull)
  derivedEventId String?

  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId String?

  concept   MemoryConcept? @relation(fields: [conceptId], references: [id], onDelete: SetNull)
  conceptId String?

  position        Int     @default(0)
  fingerprint     String
  kind            String
  label           String
  canonical       String?
  amount          Float?
  unit            String?
  durationMinutes Float?
  confidence      Float   @default(0.5)
  origin          String
  status          String  @default("accepted")
  data            Json?
  evidence        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  corrections MemoryCorrection[]
  entities    MemoryFactEntity[]

  @@unique([rawEntryId, fingerprint])
  @@index([userId, status])
  @@index([userId, kind])
  @@index([userId, canonical])
  @@index([rawEntryId])
  @@index([categoryId])
  @@index([conceptId])
}

// Stable, language-neutral labels. Categories remain user-facing views;
// concepts describe what a fact means across Croatian, English and aliases.
model MemoryConcept {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId String?

  key         String
  displayName String
  domain      String
  factKind    String
  description String?
  defaultUnit String?
  source      String   @default("catalog")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  aliases    MemoryConceptAlias[]
  facts      MemoryFact[]
  entries    MemoryEntryConcept[]
  embeddings MemoryConceptEmbedding[]

  @@unique([userId, key])
  @@index([userId, domain])
  @@index([categoryId])
}

model MemoryConceptAlias {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  concept   MemoryConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  conceptId String

  phrase           String
  normalizedPhrase String
  language         String?
  confidence       Float    @default(1)
  source           String   @default("catalog")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, normalizedPhrase])
  @@index([conceptId])
}

model MemoryEntryConcept {
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  rawEntry   Event  @relation(fields: [rawEntryId], references: [id], onDelete: Cascade)
  rawEntryId String

  concept   MemoryConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  conceptId String

  role       String   @default("secondary")
  confidence Float    @default(0.5)
  origin     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@id([rawEntryId, conceptId])
  @@index([userId, role])
  @@index([conceptId])
}

model MemoryConceptEmbedding {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  concept   MemoryConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  conceptId String

  model       String
  version     String
  dimensions  Int
  searchText  String
  contentHash String
  status      String                 @default("queued")
  attempt     Int                    @default(0)
  errorCode   String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  embedding   Unsupported("vector")?

  @@unique([conceptId, model, version])
  @@index([userId, model, version])
  @@index([userId, status])
}

// A durable audit trail for every extraction/reprocessing attempt. The app can
// recover queued or interrupted runs after a restart without risking raw data.
model MemoryProcessingRun {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  rawEntry   Event  @relation(fields: [rawEntryId], references: [id], onDelete: Cascade)
  rawEntryId String

  attempt       Int       @default(1)
  status        String    @default("queued")
  parserVersion String?
  provider      String?
  model         String?
  errorCode     String?
  result        Json?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([rawEntryId, attempt])
  @@index([userId, status])
  @@index([rawEntryId, createdAt])
}

model MemoryCorrection {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  rawEntry   Event  @relation(fields: [rawEntryId], references: [id], onDelete: Cascade)
  rawEntryId String

  fact   MemoryFact? @relation(fields: [factId], references: [id], onDelete: SetNull)
  factId String?

  action    String
  before    Json?
  after     Json?
  note      String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([rawEntryId])
  @@index([factId])
}

// Personal aliases are learned only from explicit user corrections.
model MemoryAlias {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId String?

  phrase           String
  normalizedPhrase String
  canonical        String
  kind             String?
  confidence       Float    @default(1)
  source           String   @default("correction")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, normalizedPhrase])
  @@index([userId, canonical])
  @@index([categoryId])
}

model MemoryEntity {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  kind           String
  name           String
  normalizedName String
  aliases        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  facts MemoryFactEntity[]

  @@unique([userId, kind, normalizedName])
  @@index([userId, normalizedName])
}

model MemoryFactEntity {
  fact   MemoryFact @relation(fields: [factId], references: [id], onDelete: Cascade)
  factId String

  entity   MemoryEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  entityId String

  role       String?
  confidence Float   @default(1)

  @@id([factId, entityId])
  @@index([entityId])
}

// Inferences are deliberately separate from facts and always carry evidence.
model MemoryInference {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  kind             String
  statement        String
  confidence       Float     @default(0.5)
  status           String    @default("suggested")
  evidenceEntryIds Json
  data             Json?
  validFrom        DateTime?
  validTo          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId, status])
  @@index([userId, kind])
}

// A rebuildable search projection. The raw NOTE and MemoryFact rows remain the
// source of truth; changing an embedding model never rewrites either of them.
model MemoryEmbedding {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  rawEntry   Event  @relation(fields: [rawEntryId], references: [id], onDelete: Cascade)
  rawEntryId String

  model       String
  version     String
  dimensions  Int
  searchText  String
  contentHash String
  status      String    @default("queued")
  attempt     Int       @default(0)
  errorCode   String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Prisma keeps metadata CRUD available while vector similarity is handled
  // through parameterized SQL, because pgvector is not a native Prisma scalar.
  embedding Unsupported("vector")?

  @@unique([rawEntryId, model, version])
  @@index([userId, status])
  @@index([userId, model, version])
  @@index([rawEntryId])
}

model ApiKey {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  name        String
  tokenHash   String    @unique
  tokenPrefix String
  scope       String    @default("raw_entry:write")
  expiresAt   DateTime?
  revokedAt   DateTime?
  lastUsedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tokenHash])
}

// Trustworthy context is an additive workspace layer. Existing personal
// memory remains keyed by userId until a separately reviewed migration.
model Workspace {
  id String @id @default(uuid())

  creator   User?   @relation("WorkspaceCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  creatorId String?

  slug          String
  name          String
  type          String   @default("personal")
  status        String   @default("active")
  policyVersion String   @default("context-policy-v1")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members           WorkspaceMember[]
  sourceConnections SourceConnection[]
  sourceObjects     SourceObject[]
  sourceVersions    SourceVersion[]
  claims            Claim[]
  retrievalTraces   RetrievalTrace[]
  contextPackets    ContextPacket[]

  @@unique([slug])
  @@index([type, status])
  @@index([creatorId])
}

model WorkspaceMember {
  id String @id @default(uuid())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  role              String    @default("member")
  status            String    @default("active")
  permissionVersion Int       @default(1)
  joinedAt          DateTime  @default(now())
  suspendedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  connectionAccesses SourceConnectionAccess[]
  objectAccesses     SourceObjectAccess[]
  reviewedClaims     Claim[]                  @relation("ClaimReviewer")
  retrievalTraces    RetrievalTrace[]
  contextPackets     ContextPacket[]

  @@unique([workspaceId, userId])
  @@index([userId, status])
  @@index([workspaceId, role, status])
}

model SourceConnection {
  id String @id @default(uuid())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  provider          String
  externalAccountId String
  displayName       String
  credentialRef     String
  config            Json
  status            String    @default("active")
  syncCursor        Json?
  permissionVersion Int       @default(1)
  lastSyncAt        DateTime?
  lastSyncError     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accesses SourceConnectionAccess[]
  objects  SourceObject[]

  @@unique([workspaceId, provider, externalAccountId])
  @@index([workspaceId, status])
  @@index([provider, status])
}

model SourceConnectionAccess {
  id String @id @default(uuid())

  sourceConnection   SourceConnection @relation(fields: [sourceConnectionId], references: [id], onDelete: Cascade)
  sourceConnectionId String

  workspaceMember   WorkspaceMember @relation(fields: [workspaceMemberId], references: [id], onDelete: Cascade)
  workspaceMemberId String

  permission        String    @default("read")
  upstreamPrincipal Json?
  permissionVersion Int       @default(1)
  observedAt        DateTime  @default(now())
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  objectAccesses SourceObjectAccess[]

  @@unique([sourceConnectionId, workspaceMemberId])
  @@index([workspaceMemberId, permission, revokedAt])
}

model SourceObject {
  id String @id @default(uuid())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  sourceConnection   SourceConnection @relation(fields: [sourceConnectionId], references: [id], onDelete: Cascade)
  sourceConnectionId String

  provider        String
  objectType      String
  externalId      String
  stableKey       String
  canonicalUrl    String?
  upstreamScope   String
  status          String    @default("active")
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  sourceDeletedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  versions     SourceVersion[]
  accessGrants SourceObjectAccess[]

  @@unique([sourceConnectionId, objectType, externalId])
  @@unique([workspaceId, stableKey])
  @@index([workspaceId, provider, objectType])
  @@index([sourceConnectionId, status])
}

model SourceObjectAccess {
  id String @id @default(uuid())

  sourceObject   SourceObject @relation(fields: [sourceObjectId], references: [id], onDelete: Cascade)
  sourceObjectId String

  sourceConnectionAccess   SourceConnectionAccess @relation(fields: [sourceConnectionAccessId], references: [id], onDelete: Cascade)
  sourceConnectionAccessId String

  workspaceMember   WorkspaceMember @relation(fields: [workspaceMemberId], references: [id], onDelete: Cascade)
  workspaceMemberId String

  permission                        String    @default("read")
  sourcePermissionVersion           Int
  connectionPermissionVersion       Int
  connectionAccessPermissionVersion Int
  observedAt                        DateTime  @default(now())
  revokedAt                         DateTime?
  createdAt                         DateTime  @default(now())
  updatedAt                         DateTime  @updatedAt

  @@unique([sourceObjectId, workspaceMemberId])
  @@index([workspaceMemberId, permission, revokedAt])
  @@index([sourceConnectionAccessId])
}

// Immutable raw evidence. The migration adds a trigger rejecting UPDATE and
// DELETE; normalizedText is stored with each version and rebuilt by appending a
// new version if the projection policy changes materially.
model SourceVersion {
  id String @id @default(uuid())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  sourceObject   SourceObject @relation(fields: [sourceObjectId], references: [id], onDelete: Cascade)
  sourceObjectId String

  previousVersion   SourceVersion?  @relation("SourceVersionChain", fields: [previousVersionId], references: [id], onDelete: Restrict)
  previousVersionId String?
  nextVersions      SourceVersion[] @relation("SourceVersionChain")

  ordinal         Int
  externalVersion String?
  contentHash     String
  rawPayload      Json
  normalizedText  String
  sourceUpdatedAt DateTime?
  ingestedAt      DateTime  @default(now())

  evidence ClaimEvidence[]

  @@unique([sourceObjectId, ordinal])
  @@unique([sourceObjectId, contentHash])
  @@index([workspaceId, ingestedAt])
  @@index([sourceObjectId, sourceUpdatedAt])
  @@index([previousVersionId])
}

model Claim {
  id String @id @default(uuid())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  reviewedByMember   WorkspaceMember? @relation("ClaimReviewer", fields: [reviewedByMemberId], references: [id], onDelete: SetNull)
  reviewedByMemberId String?

  supersedesClaim   Claim?  @relation("ClaimSupersession", fields: [supersedesClaimId], references: [id], onDelete: Restrict)
  supersedesClaimId String?
  supersededBy      Claim[] @relation("ClaimSupersession")

  claimKey      String
  kind          String
  statement     String
  status        String    @default("proposed")
  confidence    Float     @default(0.5)
  proposerType  String    @default("deterministic")
  proposerRef   String?
  policyVersion String
  validFrom     DateTime?
  validTo       DateTime?
  freshUntil    DateTime?
  reviewNote    String?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  evidence     ClaimEvidence[]
  packetClaims ContextPacketClaim[]

  @@index([workspaceId, status, freshUntil])
  @@index([workspaceId, claimKey, createdAt])
  @@index([reviewedByMemberId])
  @@index([supersedesClaimId])
}

// Evidence edges are append-only. The migration adds the same immutability
// trigger used for SourceVersion rows.
model ClaimEvidence {
  id String @id @default(uuid())

  claim   Claim  @relation(fields: [claimId], references: [id], onDelete: Cascade)
  claimId String

  sourceVersion   SourceVersion @relation(fields: [sourceVersionId], references: [id], onDelete: Restrict)
  sourceVersionId String

  role        String   @default("supports")
  locator     Json?
  excerpt     String?
  excerptHash String?
  relevance   Float    @default(1)
  createdAt   DateTime @default(now())

  @@unique([claimId, sourceVersionId, role])
  @@index([sourceVersionId])
  @@index([claimId, role])
}

model RetrievalTrace {
  id String @id @default(uuid())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  requesterMember   WorkspaceMember @relation(fields: [requesterMemberId], references: [id], onDelete: Restrict)
  requesterMemberId String

  query                   String
  queryHash               String
  policyVersion           String
  permissionSnapshot      Json
  permissionSnapshotHash  String
  stages                  Json
  candidateCount          Int      @default(0)
  includedCount           Int      @default(0)
  permissionExcludedCount Int      @default(0)
  staleExcludedCount      Int      @default(0)
  status                  String   @default("complete")
  createdAt               DateTime @default(now())

  packet ContextPacket?

  @@index([workspaceId, requesterMemberId, createdAt])
  @@index([workspaceId, queryHash, createdAt])
  @@index([permissionSnapshotHash])
}

model ContextPacket {
  id String @id @default(uuid())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  requesterMember   WorkspaceMember @relation(fields: [requesterMemberId], references: [id], onDelete: Restrict)
  requesterMemberId String

  retrievalTrace   RetrievalTrace @relation(fields: [retrievalTraceId], references: [id], onDelete: Restrict)
  retrievalTraceId String         @unique

  previousPacket   ContextPacket?  @relation("ContextPacketDiff", fields: [previousPacketId], references: [id], onDelete: Restrict)
  previousPacketId String?
  nextPackets      ContextPacket[] @relation("ContextPacketDiff")

  queryHash              String
  permissionSnapshotHash String
  policyVersion          String
  content                Json
  diff                   Json
  packetHash             String
  freshUntil             DateTime?
  createdAt              DateTime  @default(now())

  claims ContextPacketClaim[]

  @@index([workspaceId, requesterMemberId, queryHash, createdAt])
  @@index([previousPacketId])
  @@index([packetHash])
}

model ContextPacketClaim {
  contextPacket   ContextPacket @relation(fields: [contextPacketId], references: [id], onDelete: Cascade)
  contextPacketId String

  claim   Claim  @relation(fields: [claimId], references: [id], onDelete: Restrict)
  claimId String

  rank  Int
  score Float

  @@id([contextPacketId, claimId])
  @@unique([contextPacketId, rank])
  @@index([claimId])
}
